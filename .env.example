# AI Error Decoder - 环境变量配置示例
# 复制此文件为 .env 并填入你的实际值

# ============================================
# DigitalOcean AI/ML 服务配置
# ============================================

# DigitalOcean API Token (用于访问 DigitalOcean 的 AI 服务)
# 获取地址: https://cloud.digitalocean.com/account/api/tokens
DIGITALOCEAN_API_TOKEN=your_digitalocean_api_token_here

# OpenAI API Key (备用方案，支持 GPT-4)
OPENAI_API_KEY=your_openai_api_key_here

# ============================================
# 应用配置
# ============================================

# AI 模型选择 (gpt-3.5-turbo / gpt-4 / claude-2)
AI_MODEL=gpt-3.5-turbo

# 日志级别 (DEBUG / INFO / WARNING / ERROR)
LOG_LEVEL=INFO

# ============================================
# 安全说明
# ============================================
# ⚠️ 重要: 绝对不要将 .env 文件提交到 GitHub！
# .env 文件已在 .gitignore 中忽略
